{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "typeRoots": ["./types", "./node_modules/@types"],
  "include": ["**/*.ts", "./types"],
  "exclude": ["node_modules", "dist"]
}
